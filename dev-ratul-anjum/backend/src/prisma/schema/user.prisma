model User {
  id        String  @id @default(uuid())
  name      String
  bio       String?
  email     String? @unique
  password  String?
  photo     String?
  googleId  String?
  twitterId String?
  githubId  String?

  createdConversations       Conversation[] @relation("ConversationCreator")
  participatingConversations Conversation[] @relation("ConversationParticipant")
  sentMessages               Message[]      @relation("MessageSender")
  receivedMessages           Message[]      @relation("MessageReceiver")
  blockedBy                  UserBlock[]    @relation("blockedBy")
  blocking                   UserBlock[]    @relation("blocking")
  reportsMade                UserReport[]   @relation("reportsMade")
  reportsGot                 UserReport[]   @relation("reportsGot")

  @@map("users")
}
